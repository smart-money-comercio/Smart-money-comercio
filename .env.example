# ============================================================
# Smart Money AI Telegram Bot
# Environment Variable Template
# ============================================================
# Copy this file to .env and fill in real values.
# Never commit your real .env file to GitHub.
# Do not paste secrets into ChatGPT.
# ============================================================


# ------------------------------------------------------------
# Telegram Bot
# ------------------------------------------------------------

# Bot token from BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Admin chat ID or comma-separated admin chat IDs
# Example:
# TELEGRAM_ADMIN_CHAT_ID=123456789
# TELEGRAM_ADMIN_CHAT_ID=123456789,987654321
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id_here


# ------------------------------------------------------------
# Daily Report Automation
# ------------------------------------------------------------

# Enable or disable scheduled daily report
TELEGRAM_DAILY_REPORT_ENABLED=true

# Daily report send time
# Format: HH:MM
TELEGRAM_DAILY_REPORT_TIME=08:30

# Timezone for scheduled daily report
TELEGRAM_DAILY_REPORT_TIMEZONE=America/Lima

# Destination for scheduled report.
# Use a channel username for a public channel:
# TELEGRAM_DAILY_REPORT_CHAT_ID=@YourChannelUsername
#
# Use a private channel/group ID for private destinations:
# TELEGRAM_DAILY_REPORT_CHAT_ID=-1001234567890
#
# Supports comma-separated destinations:
# TELEGRAM_DAILY_REPORT_CHAT_ID=@ChannelOne,-1001234567890
TELEGRAM_DAILY_REPORT_CHAT_ID=your_daily_report_channel_or_chat_id_here


# ------------------------------------------------------------
# OpenAI
# ------------------------------------------------------------

# OpenAI API key
OPENAI_API_KEY=your_openai_api_key_here


# ------------------------------------------------------------
# SEC API / EDGAR
# ------------------------------------------------------------

# SEC requires a descriptive user agent.
# Recommended format:
# Your Name your-email@example.com
SEC_USER_AGENT=Your Name your-email@example.com

# Optional alternate SEC user agent variable if any module uses it
SEC_API_USER_AGENT=Your Name your-email@example.com


# ------------------------------------------------------------
# Optional Project Settings
# ------------------------------------------------------------

# App environment
APP_ENV=production

# Logging level
LOG_LEVEL=INFO


# ------------------------------------------------------------
# Optional Feature Flags
# ------------------------------------------------------------

# Enable cache behavior if your modules use this later
CACHE_ENABLED=true

# Default watchlist alert threshold, if you decide to wire this later
WATCHLIST_ALERT_THRESHOLD_PERCENT=2.0

# Startup alert enabled
TELEGRAM_STARTUP_ALERT_ENABLED=true
TELEGRAM_STARTUP_ALERT_CHAT_ID=your_admin_chat_id_here

# Watchlist alerts enabled
TELEGRAM_WATCHLIST_ALERTS_ENABLED=true
TELEGRAM_WATCHLIST_ALERT_CHAT_ID=your_admin_chat_id_here
WATCHLIST_ALERT_THRESHOLD_PERCENT=2.0
WATCHLIST_ALERT_SCAN_TIMES=10:00,12:30,15:30
WATCHLIST_ALERT_TIMEZONE=America/New_York